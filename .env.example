# Zama relayer (see https://docs.zama.org/protocol/sdk/getting-started/quick-start)
# Sepolia testnet uses the public relayer — no API key needed.
# Mainnet requires authentication in browser builds:

# VITE_RELAYER_API_KEY=your-mainnet-api-key
# VITE_RELAYER_PROXY_URL_MAINNET=https://your-app.com/api/relayer/1

# Optional RPC overrides
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Public URL of the deployed web dApp (baked into the extension at build time)
# For production: https://zproxima.vercel.app
# For local dev: http://localhost:5174
VITE_COMPANION_URL=https://zproxima.vercel.app
