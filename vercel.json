{
  "outputDirectory": "companion-dist",
  "rewrites": [
    {
      "source": "/api/rpc/11155111",
      "destination": "https://ethereum-sepolia-rpc.publicnode.com"
    },
    {
      "source": "/api/rpc/1",
      "destination": "https://ethereum-rpc.publicnode.com"
    },
    {
      "source": "/api/relayer/11155111/:path*",
      "destination": "https://relayer.testnet.zama.org/v2/:path*"
    },
    {
      "source": "/api/relayer/1/:path*",
      "destination": "https://relayer.mainnet.zama.org/v2/:path*"
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ]
}
