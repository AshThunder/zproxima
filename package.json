{
  "name": "zproxima-ext",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build && npm run build:companion",
    "build:ext": "tsc -b && vite build",
    "build:companion": "vite build --config companion/vite.config.ts && cp companion/vercel.json companion-dist/vercel.json",
    "serve:companion": "vite preview --config companion/vite.config.ts --port 5174 --strictPort",
    "dev": "vite --port 5173",
    "dev:companion": "vite --config companion/vite.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@zama-fhe/sdk": "^3.2.0",
    "ethers": "^6.13.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@types/chrome": "^0.0.280",
    "@types/node": "^22.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "solc": "^0.8.35",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
